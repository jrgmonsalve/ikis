rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function familyPath(familyId) {
      return /databases/$(database)/documents/families/$(familyId);
    }

    function isInitialOwnerMemberCreate(familyId, memberId) {
      return isSignedIn()
        && request.auth.uid == memberId
        && request.resource.data.id == memberId
        && request.resource.data.familyId == familyId
        && request.resource.data.userId == memberId
        && request.resource.data.role == "owner"
        && request.resource.data.status == "active"
        && getAfter(familyPath(familyId)).data.ownerUserId == request.auth.uid
        && getAfter(familyPath(familyId)).data.status == "active";
    }

    function memberPath(familyId, userId) {
      return /databases/$(database)/documents/families/$(familyId)/members/$(userId);
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isFamilyMember(familyId) {
      return isSignedIn()
        && exists(memberPath(familyId, request.auth.uid))
        && get(memberPath(familyId, request.auth.uid)).data.status == "active";
    }

    function memberRole(familyId) {
      return get(memberPath(familyId, request.auth.uid)).data.role;
    }

    function isOwner(familyId) {
      return isFamilyMember(familyId) && memberRole(familyId) == "owner";
    }

    function isAdminOrOwner(familyId) {
      return isFamilyMember(familyId)
        && memberRole(familyId) in ["owner", "admin"];
    }

    function isActiveMember(familyId) {
      return isFamilyMember(familyId)
        && memberRole(familyId) in ["owner", "admin", "member"];
    }

    function isOwnActiveMemberDocument() {
      return isSignedIn()
        && resource.data.userId == request.auth.uid
        && resource.data.status == "active";
    }

    function validLanguage(language) {
      return language in ["en", "es"];
    }

    function validCurrency(currency) {
      return currency in ["COP", "USD"];
    }

    function validFamilyStatus(status) {
      return status in ["active", "inactive"];
    }

    function validMemberRole(role) {
      return role in ["owner", "admin", "member"];
    }

    function validMemberStatus(status) {
      return status in ["active", "inactive", "removed"];
    }

    function validInvitationStatus(status) {
      return status in ["pending", "accepted", "expired", "cancelled"];
    }

    function validAccountType(type) {
      return type in ["savings", "cash", "digital_wallet", "credit_card"];
    }

    function validAccountStatus(status) {
      return status in ["active", "inactive"];
    }

    function validCategoryStatus(status) {
      return status in ["active", "inactive"];
    }

    function validBudgetPeriodType(periodType) {
      return periodType in ["monthly", "yearly", "custom"];
    }

    function hasNoActivePeriod(data) {
      return !data.keys().hasAny(["activePeriod"]) || data.activePeriod == null;
    }

    function validMonthlyActivePeriod(period) {
      return period.periodType == "monthly"
        && period.month is number
        && period.month >= 1
        && period.month <= 12
        && period.year is number
        && period.year >= 2020
        && period.year <= 2100
        && period.customStart == null
        && period.customEnd == null;
    }

    function validYearlyActivePeriod(period) {
      return period.periodType == "yearly"
        && period.month == null
        && period.year is number
        && period.year >= 2020
        && period.year <= 2100
        && period.customStart == null
        && period.customEnd == null;
    }

    function validCustomActivePeriod(period) {
      return period.periodType == "custom"
        && period.month == null
        && period.year == null
        && period.customStart is timestamp
        && period.customEnd is timestamp
        && period.customStart <= period.customEnd;
    }

    function validFamilyActivePeriod(data) {
      return hasNoActivePeriod(data)
        || (
          data.activePeriod is map
          && data.activePeriod.keys().hasOnly(["periodType", "month", "year", "customStart", "customEnd"])
          && (
            validMonthlyActivePeriod(data.activePeriod)
            || validYearlyActivePeriod(data.activePeriod)
            || validCustomActivePeriod(data.activePeriod)
          )
        );
    }

    function validBudgetStatus(status) {
      return status in ["active", "inactive"];
    }

    function validRecurringFrequency(frequency) {
      return frequency in ["weekly", "biweekly", "monthly", "yearly", "custom"];
    }

    function validRecurringStatus(status) {
      return status in ["active", "inactive"];
    }

    function validPositiveAmount(amount) {
      return amount is number && amount > 0;
    }

    function sameFamily(familyId) {
      return request.resource.data.familyId == familyId;
    }

    function createdByCurrentUser() {
      return request.resource.data.createdByUserId == request.auth.uid;
    }

    // Collection group query used to list the current user's active families.
    match /{path=**}/members/{memberId} {
      allow list: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && resource.data.status == "active";
    }

    match /users/{userId} {
      allow read: if isSelf(userId);

      allow create: if isSelf(userId)
        && request.resource.data.id == userId
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && validLanguage(request.resource.data.preferredLanguage)
        && request.resource.data.status in ["active", "inactive"];

      allow update: if isSelf(userId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.email == resource.data.email
        && validLanguage(request.resource.data.preferredLanguage)
        && request.resource.data.status in ["active", "inactive"];

      allow delete: if false;
    }

    match /families/{familyId} {
      allow read: if isActiveMember(familyId);

      allow create: if isSignedIn()
        && request.resource.data.id == familyId
        && request.resource.data.ownerUserId == request.auth.uid
        && request.resource.data.name is string
        && validCurrency(request.resource.data.mainCurrency)
        && validFamilyActivePeriod(request.resource.data)
        && validFamilyStatus(request.resource.data.status);

      allow update: if isOwner(familyId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.ownerUserId == resource.data.ownerUserId
        && request.resource.data.name is string
        && validCurrency(request.resource.data.mainCurrency)
        && validFamilyActivePeriod(request.resource.data)
        && validFamilyStatus(request.resource.data.status);

      allow delete: if false;

      match /members/{memberId} {
        allow read: if isActiveMember(familyId) || isOwnActiveMemberDocument();

        allow create: if (isOwner(familyId) || isInitialOwnerMemberCreate(familyId, memberId))
          && request.resource.data.id == memberId
          && request.resource.data.familyId == familyId
          && request.resource.data.userId == memberId
          && request.resource.data.email is string
          && request.resource.data.displayName is string
          && validMemberRole(request.resource.data.role)
          && validMemberStatus(request.resource.data.status);

        allow update: if isOwner(familyId)
          && request.resource.data.id == resource.data.id
          && request.resource.data.familyId == familyId
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.email == resource.data.email
          && request.resource.data.role in ["admin", "member", "owner"]
          && validMemberStatus(request.resource.data.status)
          && !(resource.data.role == "owner" && request.resource.data.status == "removed");

        allow delete: if false;
      }

      match /invitations/{invitationId} {
        allow read: if isOwner(familyId);

        allow create: if isOwner(familyId)
          && request.resource.data.id == invitationId
          && sameFamily(familyId)
          && request.resource.data.email is string
          && request.resource.data.role in ["admin", "member"]
          && request.resource.data.invitedByUserId == request.auth.uid
          && validInvitationStatus(request.resource.data.status)
          && request.resource.data.status == "pending";

        allow update: if isOwner(familyId)
          && resource.data.status == "pending"
          && request.resource.data.id == resource.data.id
          && request.resource.data.familyId == familyId
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == resource.data.role
          && request.resource.data.invitedByUserId == resource.data.invitedByUserId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.expiresAt == resource.data.expiresAt
          && request.resource.data.acceptedAt == resource.data.acceptedAt
          && request.resource.data.status == "cancelled";

        allow delete: if false;
      }

      match /accounts/{accountId} {
        allow read: if isActiveMember(familyId);

        allow create: if isAdminOrOwner(familyId)
          && request.resource.data.id == accountId
          && sameFamily(familyId)
          && request.resource.data.name is string
          && validAccountType(request.resource.data.type)
          && request.resource.data.initialBalance is number
          && request.resource.data.initialBalance >= 0
          && request.resource.data.currentBalance == request.resource.data.initialBalance
          && request.resource.data.currency == get(familyPath(familyId)).data.mainCurrency
          && createdByCurrentUser()
          && validAccountStatus(request.resource.data.status);

        allow update: if isAdminOrOwner(familyId)
          && request.resource.data.id == resource.data.id
          && request.resource.data.familyId == familyId
          && request.resource.data.createdByUserId == resource.data.createdByUserId
          && request.resource.data.name is string
          && request.resource.data.type == resource.data.type
          && request.resource.data.initialBalance == resource.data.initialBalance
          && request.resource.data.currentBalance == resource.data.currentBalance
          && request.resource.data.currency == resource.data.currency
          && validAccountStatus(request.resource.data.status);

        allow delete: if false;
      }

      match /categories/{categoryId} {
        allow read: if isActiveMember(familyId);

        allow create: if isAdminOrOwner(familyId)
          && request.resource.data.id == categoryId
          && sameFamily(familyId)
          && request.resource.data.name is string
          && request.resource.data.normalizedName is string
          && createdByCurrentUser()
          && validCategoryStatus(request.resource.data.status);

        allow update: if isAdminOrOwner(familyId)
          && request.resource.data.id == resource.data.id
          && request.resource.data.familyId == familyId
          && request.resource.data.createdByUserId == resource.data.createdByUserId
          && request.resource.data.name is string
          && request.resource.data.normalizedName is string
          && validCategoryStatus(request.resource.data.status);

        allow delete: if false;
      }

      match /transactions/{transactionId} {
        allow read: if isActiveMember(familyId);

        // Critical financial writes are handled by Cloud Functions using Admin SDK.
        allow create: if false;

        allow update: if false;

        allow delete: if false;
      }

      match /budgets/{budgetId} {
        allow read: if isActiveMember(familyId);

        allow create: if isAdminOrOwner(familyId)
          && request.resource.data.id == budgetId
          && sameFamily(familyId)
          && request.resource.data.name is string
          && request.resource.data.categoryId is string
          && validPositiveAmount(request.resource.data.plannedAmount)
          && validBudgetPeriodType(request.resource.data.periodType)
          && validCurrency(request.resource.data.currency)
          && createdByCurrentUser()
          && validBudgetStatus(request.resource.data.status);

        allow update: if isAdminOrOwner(familyId)
          && request.resource.data.id == resource.data.id
          && request.resource.data.familyId == familyId
          && request.resource.data.createdByUserId == resource.data.createdByUserId
          && request.resource.data.name is string
          && request.resource.data.categoryId is string
          && validPositiveAmount(request.resource.data.plannedAmount)
          && validBudgetPeriodType(request.resource.data.periodType)
          && validCurrency(request.resource.data.currency)
          && validBudgetStatus(request.resource.data.status);

        allow delete: if false;
      }

      match /recurringPayments/{recurringPaymentId} {
        allow read: if isActiveMember(familyId);

        allow create: if isAdminOrOwner(familyId)
          && request.resource.data.id == recurringPaymentId
          && sameFamily(familyId)
          && request.resource.data.name is string
          && validPositiveAmount(request.resource.data.expectedAmount)
          && validRecurringFrequency(request.resource.data.frequency)
          && request.resource.data.nextDueDate is timestamp
          && validCurrency(request.resource.data.currency)
          && createdByCurrentUser()
          && validRecurringStatus(request.resource.data.status);

        allow update: if isAdminOrOwner(familyId)
          && request.resource.data.id == resource.data.id
          && request.resource.data.familyId == familyId
          && request.resource.data.createdByUserId == resource.data.createdByUserId
          && request.resource.data.name is string
          && validPositiveAmount(request.resource.data.expectedAmount)
          && validRecurringFrequency(request.resource.data.frequency)
          && request.resource.data.nextDueDate is timestamp
          && validCurrency(request.resource.data.currency)
          && validRecurringStatus(request.resource.data.status);

        allow delete: if false;
      }

      match /dashboardSnapshots/{snapshotId} {
        allow read: if isActiveMember(familyId);

        // Recommended: only server-side code using Admin SDK should write snapshots.
        // Admin SDK bypasses Firestore security rules.
        allow write: if false;
      }
    }
  }
}
