{
  "name": "ikis",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "npm --prefix apps/web start",
    "build": "npm --prefix apps/web run build && npm --prefix functions run build",
    "build:web": "npm --prefix apps/web run build",
    "build:functions": "npm --prefix functions run build",
    "test:web": "npm --prefix apps/web test",
    "test:rules": "firebase emulators:exec --only firestore \"npm --prefix tests/firestore test\"",
    "validate": "npm run lint:functions && npm run test:web && npm run test:rules && npm run build",
    "lint:functions": "npm --prefix functions run lint",
    "emulators": "npm --prefix functions run build && firebase emulators:start --only auth,firestore,functions",
    "emulators:export": "npm --prefix functions run build && firebase emulators:start --only auth,firestore,functions --export-on-exit=./.firebase-emulator-data",
    "dev": "bash scripts/dev.sh",
    "dev:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "local:start": "bash scripts/local-env.sh start",
    "local:stop": "bash scripts/local-env.sh stop",
    "local:restart": "bash scripts/local-env.sh restart",
    "local:status": "bash scripts/local-env.sh status",
    "local:logs": "bash scripts/local-env.sh logs",
    "local:start:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local-env.ps1 start",
    "local:stop:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local-env.ps1 stop",
    "local:restart:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local-env.ps1 restart",
    "local:status:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local-env.ps1 status",
    "local:logs:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/local-env.ps1 logs"
  }
}
