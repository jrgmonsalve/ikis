{
  "name": "@ikis/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply ikis --local",
    "db:migrate:remote": "wrangler d1 migrations apply ikis --remote"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.6",
    "hono": "^4.10.7"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "@cloudflare/workers-types": "^4.20260701.0",
    "@types/node": "^26.1.0",
    "drizzle-kit": "^0.31.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.107.0"
  }
}
